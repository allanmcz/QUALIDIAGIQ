# Variáveis de ambiente do QDI — copie este arquivo para `.env` e ajuste

# === Supabase ===
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:postgres@localhost:60322/postgres

# === Anthropic Claude (LLM principal) ===
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# === OpenAI (fallback) ===
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4-turbo

# === FastAPI ===
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_RELOAD=true

# === JWT (obrigatório em produção: mín. 32 caracteres) ===
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# === CORS (lista separada por vírgula; não use * com credentials) ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === Multi-tenant ===
# Tenant vem do claim JWT após login — ver `POST /auth/login`

# === Idempotência (POST /diagnosticos/) — cache em memória MVP ===
# IDEMPOTENCY_TTL_SECONDS=3600
# IDEMPOTENCY_MAX_ENTRIES=10000

# === Observabilidade (OpenTelemetry) ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=qdi-api

# === E-mail (envio de relatórios) ===
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=qdi@tributiq.com.br

# === LGPD ===
LGPD_RETENTION_DAYS=180
LGPD_DPO_EMAIL=dpo@tributiq.com.br
