# Variáveis de ambiente do QDI — copie este arquivo para `.env` e ajuste

# === Supabase ===
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:postgres@localhost:60322/postgres

# === Testes de integração e gates MVP (make mvp-gate, verify-schema-mvp*) ===
# Alinha o pytest de integração ao mesmo Postgres do Docker Compose (make dev → porta host 60322).
# Em CI (GitHub Actions) usa-se tipicamente localhost:5432 — definido no workflow, não aqui.
# QDI_POSTGRES_TEST_URL=postgresql://postgres:postgres@127.0.0.1:60322/postgres
# Role usada nos testes RLS automatizados (default documentado em tests/integration/test_mvp_gate_postgres.py).
# QDI_RLS_TEST_ROLE_PASSWORD=qdi_rls_smoke_ci_only

# === Ollama local (LLM padrão em dev — recomendações no diagnóstico) ===
# 1) Instale e rode o app: https://ollama.com
# 2) Baixe o modelo alinhado a OLLAMA_MODEL: `ollama pull llama3`
# 3) URL conforme onde roda a API FastAPI:
#    • API no host (uvicorn direto): OLLAMA_BASE_URL=http://127.0.0.1:11434
#    • API no Docker (`make dev`): use host.docker.internal (já é o default no docker-compose.yml)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
# Timeout HTTP (s) para POST /api/generate no Ollama (evita worker travado).
OLLAMA_TIMEOUT_SECONDS=30

# OpenTelemetry (opcional) — traces OTLP/HTTP para collector local ou SaaS.
# OTEL_TRACING_ENABLED=true
# OTEL_SERVICE_NAME=qualidiagiq-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=api-key=seu_token

# === Anthropic Claude (planejado produção / tiers pagos — ADR-003) ===
#ANTHROPIC_API_KEY=sk-ant-...
#ANTHROPIC_MODEL=claude-sonnet-4-6

# === OpenAI (opcional / futuro) ===
#OPENAI_API_KEY=sk-...
#OPENAI_MODEL=gpt-4-turbo

# === FastAPI ===
APP_ENV=development
# Produção (QDI-H-035): cadastro público na plataforma (POST /auth/cadastro) só com opt-in explícito:
# QDI_CADASTRO_CONSULTOR_B2B_HABILITADO=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_RELOAD=true

# === JWT (obrigatório em produção: mín. 32 caracteres) ===
# Gerar: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
# Dev: sessão longa. Produção (ADR-020): JWT_EXPIRE_MINUTES deve ser ≤ 30 (validador em Settings).
JWT_EXPIRE_MINUTES=480

# === CORS (lista separada por vírgula; não use * com credentials) ===
CORS_ALLOWED_ORIGINS=http://localhost:3010,http://127.0.0.1:3010

# === Links públicos da API (PDF por e-mail; fallback /mock-storage quando Storage falha) ===
# Deve ser uma URL que o **browser** do utilizador resolve (não use http://api:8000 do Docker).
# Compose (API mapeada em 60000): QDI_PUBLIC_API_BASE_URL=http://127.0.0.1:60000
# Uvicorn local na 8000: QDI_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# QDI_PUBLIC_API_BASE_URL=http://127.0.0.1:60000

# Spool em disco para PDF quando o upload ao Supabase Storage falha (fallback /mock-storage).
# Omitir = <tempdir>/qdi-mock-pdf. API no Docker (compose) já monta volume nesse caminho.
# QDI_PDF_MOCK_SPOOL_DIR=/caminho/personalizado

# === Multi-tenant ===
# Tenant vem do claim JWT após login — ver `POST /auth/login`

# === Self-service (OTP → gravar sem conta na plataforma) ===
# Tenant dedicado no Postgres/RLS para diagnósticos após POST /auth/self-service/token.
# QDI_SELF_SERVICE_TENANT_ID=44444444-4444-4444-8444-444444444444
# Validade do JWT self-service (minutos, 5–120).
# QDI_SELF_SERVICE_JWT_EXPIRE_MINUTES=30

# === Idempotência (POST /diagnosticos/) — cache em memória MVP ===
# IDEMPOTENCY_TTL_SECONDS=3600
# IDEMPOTENCY_MAX_ENTRIES=10000

# === ADR-020 — rate-limit de rotas sensíveis (login, cadastro, OTP, rascunho self-service) ===
# QDI_SENSITIVE_RATE_LIMIT_ENABLED=true
# QDI_SENSITIVE_RATE_LIMIT_PER_MINUTE=5

# === Observabilidade (OpenTelemetry) ===
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=qdi-api

# === E-mail (OTP wizard + relatório PDF) ===
# API dentro do Docker (make dev): SMTP_HOST já vem mailpit no compose — não use localhost.
# API no host (uvicorn local) + Mailpit no host: SMTP_HOST=127.0.0.1 SMTP_PORT=1025
# UI das mensagens (dev): http://127.0.0.1:8025
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=qdi@tributiq.com.br

# === LGPD ===
# Retenção (dias) — uso interno futuro; canal DPO no site: ver frontend `NEXT_PUBLIC_LGPD_DPO_EMAIL`.
LGPD_RETENTION_DAYS=180
# E-mail do encarregado (referência institucional; espelhar em Next com NEXT_PUBLIC_LGPD_DPO_EMAIL).
# MVP: Allan Marcio (PF) como DPO provisório — allan@tributolab.com.br
LGPD_DPO_EMAIL=allan@tributolab.com.br
