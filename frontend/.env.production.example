# Exemplo de variáveis para build/run de produção (SEM segredos).
# Copiar para .env.production local apenas em máquina segura; no CI usar secrets.

# URL pública da API consumida pelo browser (HTTPS canónico).
NEXT_PUBLIC_API_URL=https://api.seu-dominio.tributiq.com.br

# URL canónica do site Next (metadata Open Graph / Twitter absolutos).
NEXT_PUBLIC_SITE_URL=https://app.seu-dominio.tributiq.com.br

# Canal público do DPO (secção `#dpo` em `/privacidade`). Obrigatório em produção comercial.
NEXT_PUBLIC_LGPD_DPO_EMAIL=dpo@tributiq.com.br
# NEXT_PUBLIC_LGPD_DPO_NOME=
# NEXT_PUBLIC_POLITICA_PRIVACIDADE_VERSAO=1.0
# NEXT_PUBLIC_POLITICA_PRIVACIDADE_VIGENCIA=2026-05-07

# Opcional: painel normativa no wizard (POST /normativa/validar-ancora).
# NEXT_PUBLIC_WIZARD_NORMATIVA=true
