{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3010",
    "build": "next build",
    "start": "next start -p 3010",
    "lighthouse": "lhci autorun",
    "lint": "next lint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=1 playwright test",
    "test:e2e:mobile": "playwright test --project=chromium-mobile",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:wizard-normativa": "PLAYWRIGHT_WIZARD_NORMATIVA=1 playwright test e2e/wizard-normativa.spec.ts",
    "test:e2e:integrado": "PLAYWRIGHT_SKIP_WEBSERVER=1 PLAYWRIGHT_INTEGRATED=1 playwright test e2e/dashboard-list-integrado.spec.ts e2e/a11y-critical.spec.ts",
    "test:e2e:integrado:ui": "PLAYWRIGHT_SKIP_WEBSERVER=1 PLAYWRIGHT_INTEGRATED=1 playwright test e2e/dashboard-list-integrado.spec.ts --ui",
    "test:e2e:integrado:headed": "PLAYWRIGHT_SKIP_WEBSERVER=1 PLAYWRIGHT_INTEGRATED=1 playwright test e2e/dashboard-list-integrado.spec.ts --headed --project=chromium-desktop",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:record-eval": "PLAYWRIGHT_WIZARD_NORMATIVA=1 PLAYWRIGHT_RECORD_EVAL=1 playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/browser": "^10.51.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.12.0",
    "next": "15.5.18",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.74.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "15.5.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
