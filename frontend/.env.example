# Next.js — base da API (fetch do browser).
# `npm run dev` / `npm start` usam a porta 3010 no host (evita colisão com outro app em :3000).
# Prefira 127.0.0.1 no Mac: "localhost" pode resolver para IPv6 e a porta do Docker não responde.
NEXT_PUBLIC_API_URL=http://127.0.0.1:60000
#
# Se **não** definir NEXT_PUBLIC_API_URL e abrir o front em localhost:3000, 3010, 3333 ou 60001,
# o cliente usa `/api-backend` (same-origin). O `next.config.mjs` infere **API_PROXY_TARGET=http://127.0.0.1:60000**
# em `next dev` no host (fora de Docker) se a variável não existir — API tem de estar exposta nessa porta.
# No container `web` do Compose, continue a usar API_PROXY_TARGET=http://api:8000 (definido no docker-compose).
#
# URL canónica do site (metadata Open Graph / Twitter). Opcional em dev.
# NEXT_PUBLIC_SITE_URL=https://seu-dominio.tributiq.com.br
#
# Next rodando **dentro** do docker-compose: use proxy same-origin (definido no compose).
# NEXT_PUBLIC_API_URL=/api-backend
# API_PROXY_TARGET=http://api:8000   # só servidor Next (rewrite), não precisa NEXT_PUBLIC_

# P8 — exibe painel “validar âncora normativa” no passo 3 do wizard (POST /normativa/validar-ancora).
# NEXT_PUBLIC_WIZARD_NORMATIVA=true

# Playwright (E2E) — alinhado a frontend/playwright.config.ts e CI (.github/workflows/ci.yml).
# PLAYWRIGHT_PORT=3333
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3333
# PLAYWRIGHT_SKIP_WEBSERVER=1
# (com SKIP: suba o Next manualmente na PLAYWRIGHT_BASE_URL antes de npm run test:e2e)
#
# P8 opcional — sobe Next com painel normativa + roda só o spec (~ npm run test:e2e:wizard-normativa).
# PLAYWRIGHT_WIZARD_NORMATIVA=1
