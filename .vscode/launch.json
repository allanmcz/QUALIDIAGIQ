{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FastAPI: dev (uvicorn reload)",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": ["src.presentation.api.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "jinja": true,
      "justMyCode": false
    },
    {
      "name": "Pytest: arquivo atual",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-vv"],
      "console": "integratedTerminal"
    },
    {
      "name": "Pytest: todos com cobertura",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/", "-vv", "--cov=src", "--cov-report=term-missing"],
      "console": "integratedTerminal"
    }
  ]
}
